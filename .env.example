# Supabase — get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — used ONLY by the Vercel serverless API (api/create-user.ts)
# Never expose this in the frontend. Set it in Vercel project environment variables.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
